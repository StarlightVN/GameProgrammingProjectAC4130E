  m_Script: {fileID: 11500000, guid: 8eb0a30870010f94291dcb2c30c4c17d, type: 3}
  m_Name: Greeting
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - speaker: 1
    text: "Th\u1EADt s\u1EF1 c\u1EA3m gi\xE1c l\u1EA5y \u0111\u01B0\u1EE3c c\xFAp
      sau 22 n\u0103m th\u1EADt tuy\u1EC7t v\u1EDDi"
  - speaker: 1
    text: "T\xF4i v\u1EABn th\u1EA5y l\xE2ng l\xE2ng c\u1EA3 ng\u01B0\u1EDDi"
  - speaker: 0
    text: "E h\xE8m"
  - speaker: 0
    text: "\u0110\u1EC1 ngh\u1ECB xu\u1EA5t tr\xECnh gi\u1EA5y t\u1EDD"
  - speaker: 1
    text: "\xC0 \u0111\xE2y, \xE0 \u0111\xE2y"
