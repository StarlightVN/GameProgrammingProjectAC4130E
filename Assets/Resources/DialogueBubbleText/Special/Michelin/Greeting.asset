  m_Script: {fileID: 11500000, guid: 8eb0a30870010f94291dcb2c30c4c17d, type: 3}
  m_Name: Greeting
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - speaker: 1
    text: "Cho t\xF4i v\xE0o v\u1EDBi nhanh nhanh kh\xF4ng b\xE1nh ngu\u1ED9i m\u1EA5t"
  - speaker: 0
    text: "Vi\u1EC7c g\xEC ph\u1EA3i v\u1ED9i th\u1EBF"
  - speaker: 1
    text: " \u0110\xE2y, check l\u1EB9 \u0111i \xF4ng"
  - speaker: 1
    text: "T\xECnh y\xEAu kh\xF4ng ch\u1EDD, b\xE1nh m\xEC c\u0169ng v\u1EADy"
  - speaker: 0
    text: "Nh\u01B0ng \xF4ng l\xE0m g\xEC m\xE0 c\u1EA7m t\u1EADn ba ph\u1EA7n b\xE1nh
      m\xEC v\u1EADy?"
  - speaker: 1
    text: "M\u1ED9t ph\u1EA7n cho crush"
  - speaker: 1
    text: "M\u1ED9t ph\u1EA7n cho ng\u01B0\u1EDDi y\xEAu c\xF4 \u1EA5y"
  - speaker: 0
    text: "\u2026"
  - speaker: 0
    text: "Th\u1EBF ph\u1EA7n c\xF2n l\u1EA1i ?"
  - speaker: 1
    text: "T\xF4i s\u1EE3 h\u1ECD \u0103n kh\xF4ng \u0111\u1EE7 no n\xEAn mua d\u1EF1
      ph\xF2ng"
  - speaker: 0
    text: ...
  - speaker: 0
    text: "T\xF4i \u0111\u1EBFn ch\u1ECBu \xF4ng"
