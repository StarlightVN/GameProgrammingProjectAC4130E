  m_Script: {fileID: 11500000, guid: 8eb0a30870010f94291dcb2c30c4c17d, type: 3}
  m_Name: Greeting
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - speaker: 0
    text: "\u0110\u1EC1 ngh\u1ECB xu\u1EA5t tr\xECnh gi\u1EA5y t\u1EDD"
  - speaker: 1
    text: "H\xF4m nay tr\u1EDDi nhi\u1EC1u kh\xF3i nh\u1EC9"
  - speaker: 0
    text: "Kh\xF3i g\xEC \u1EDF \u0111\xE2y \u0111\u01B0\u1EE3c ?"
  - speaker: 1
    text: "H\u1ECDa t\u1EEB mi\u1EC7ng m\xE0 ra"
  - speaker: 0
    text: '?'
  - speaker: 1
    text: "N\u1EBFu kh\xF4ng mu\u1ED1n b\u1ECB l\u1ED9 th\xF4ng tin "
  - speaker: 1
    text: "Th\xEC ch\u1EA5p nh\u1EADn ch\u1ECBu thi\u1EC7t m\u1ED9t ch\xFAt"
