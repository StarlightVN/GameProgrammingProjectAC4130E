  m_Script: {fileID: 11500000, guid: 8eb0a30870010f94291dcb2c30c4c17d, type: 3}
  m_Name: Deny
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - speaker: 0
    text: "Xin l\u1ED7i anh, kh\xF4ng c\xF3 gi\u1EA5y t\u1EDD h\u1EE3p l\u1EC7 n\xEAn
      em kh\xF4ng th\u1EC3 cho v\xE0o"
  - speaker: 1
    text: "\xD4i m\u1ED9t tr\xE1i tim \u0111\xE3 v\u1EE1 tan..."
  - speaker: 1
    text: "Th\xE0nh ph\u1ED1 bu\u1ED3n, nh\u1EDB kh\xF4ng em..."
  - speaker: 0
    text: "Anh b\u1ED5 sung gi\u1EA5y t\u1EDD r\u1ED3i quay l\u1EA1i gi\xFAp em \u1EA1."
