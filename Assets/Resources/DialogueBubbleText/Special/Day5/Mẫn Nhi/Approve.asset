  m_Script: {fileID: 11500000, guid: 8eb0a30870010f94291dcb2c30c4c17d, type: 3}
  m_Name: Approve
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - speaker: 1
    text: "C\u1EADu\u2026 c\u1EADu th\u1EF1c s\u1EF1 cho t\u1EDB v\xE0o \u01B0?"
  - speaker: 1
    text: "T\u1EDB bi\u1EBFt m\xE0 c\u1EADu l\xE0 ng\u01B0\u1EDDi t\u1ED1t m\xE0"
  - speaker: 0
    text: "Nh\u01B0ng ch\u1EC9 l\u1EA7n n\xE0y th\xF4i nh\xE9, l\u1EA7n sau nh\u1EDB
      gia h\u1EA1n gi\u1EA5y ph\xE9p tr\u01B0\u1EDBc"
  - speaker: 0
    text: "Nh\u01B0ng ch\u1EC9 l\u1EA7n n\xE0y th\xF4i nh\xE9, l\u1EA7n sau nh\u1EDB
      gia h\u1EA1n gi\u1EA5y ph\xE9p tr\u01B0\u1EDBc"
  - speaker: 0
    text: "\xC0 c\xF2n chuy\u1EC7n\u2026"
  - speaker: 1
    text: "T\u1EDB bi\u1EBFt r\u1ED3i..."
  - speaker: 1
    text: "\u0110\u1EE3i t\u1EDB thi xong \u0111\xE3"
  - speaker: 1
    text: "N\u1EBFu t\u1EDB qua m\xF4n, t\u1EDB mu\u1ED1n nghe c\u1EADu th\u1ED5
      l\u1ED9 tr\u1EF1c ti\u1EBFp"
  - speaker: 0
    text: "N\u1EBFu c\u1EADu r\u1EDBt th\xEC sao?"
  - speaker: 1
    text: "Th\xEC c\u1EADu ph\u1EA3i an \u1EE7i t\u1EDB"
  - speaker: 1
    text: "D\xF9 sao c\u1EADu c\u0169ng l\xE0m tr\xE1i quy \u0111\u1ECBnh r\u1ED3i"
  - speaker: 1
    text: "C\xF2n t\u1EDB ph\u1EA3i l\xF2ng c\u1EADu r\u1ED3i <3"
