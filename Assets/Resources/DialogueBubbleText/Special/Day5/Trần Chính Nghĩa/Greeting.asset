  lines:
  - speaker: 0
    text: "\u0110\u1EC1 ngh\u1ECB xu\u1EA5t tr\xECnh gi\u1EA5y t\u1EDD"
  - speaker: 1
    text: ...
  - speaker: 1
    text: "\u0110\u1ECDc b\xE1o l\xE0 m\u1ED9t c\xE1ch \u0111\u1EC3 n\xE2ng cao d\xE2n
