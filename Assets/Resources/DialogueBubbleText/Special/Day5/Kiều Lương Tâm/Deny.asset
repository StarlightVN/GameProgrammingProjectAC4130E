  m_Script: {fileID: 11500000, guid: 8eb0a30870010f94291dcb2c30c4c17d, type: 3}
  m_Name: Deny
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - speaker: 0
    text: "\u0110\u1EE9ng y\xEAn \u0111\u1EA5y"
  - speaker: 1
    text: "Gi\u1EA5y t\u1EDD c\u1EE7a t\xF4i h\u1EE3p l\u1EC7 m\xE0"
  - speaker: 0
    text: "\u0110\u1EEBng t\u01B0\u1EDFng tao kh\xF4ng bi\u1EBFt m\xE0y l\xE0 ai"
  - speaker: 1
    text: "M\xE0y \u0111\u01B0\u1EE3c l\u1EAFm, tuy nhi\xEAn"
  - speaker: 1
    text: "M\xE0y kh\xF4ng th\u1EC3 b\u1EAFt \u0111\u01B0\u1EE3c tao"
  - speaker: 0
    text: "Tao bi\u1EBFt"
  - speaker: 0
    text: "Nh\u01B0ng ng\u01B0\u1EDDi kh\xE1c th\xEC c\xF3 th\u1EC3 th\xEC c\xF3
      th\u1EC3"
  - speaker: 1
    text: '?'
  - speaker: 0
    text: "B\xC0NH TR\u01AF\u1EDANG L\xC3NH \u0110\u1ECAA:"
  - speaker: 0
    text: "B\xC1O C\xD4NG AN"
  - speaker: 1
    text: "\xC2y \xE2y, th\u1EA3 tao ra, \u0111au \u0111au \u0111au..."
