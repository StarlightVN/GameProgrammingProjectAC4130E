    showAvatar: 0
    changeBackground: 0
    background: {fileID: 0}
    backgroundColor: {r: 1, g: 1, b: 1, a: 1}
    clearBackground: 0
    voiceClip: {fileID: 0}
    soundEffect: {fileID: 0}
    eventKey: 
    inputLockDuration: 0
    autoContinue: 0
    autoContinueDelay: 1
  - speakerName: "Ng\u01B0\u1EDDi qua \u0111\u01B0\u1EDDng 2"
    content: "O\xE1ch x\xE0 l\xE1ch. Ch\u1EAFc m\u1EDBi t\u1EA1ch Gi\u1EA3i t\xEDch
