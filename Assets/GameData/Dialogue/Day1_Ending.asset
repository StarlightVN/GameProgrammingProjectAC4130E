    displayMode: 2
    avatar: {fileID: 0}
    showAvatar: 0
    changeBackground: 0
    background: {fileID: 0}
    backgroundColor: {r: 1, g: 1, b: 1, a: 1}
    clearBackground: 0
    voiceClip: {fileID: 0}
    soundEffect: {fileID: 0}
    eventKey: 
    inputLockDuration: 0
    autoContinue: 0
    autoContinueDelay: 1
  - speakerName: "Ng\u01B0\u1EDDi qua \u0111\u01B0\u1EDDng 1"
    content: "\xD4ng ch\xE1u h\u1ECDc l\u1EA1i L\xFD thuy\u1EBFt m\u1EA1ch l\u1EA7n
      3 r\u1ED3i m\xE0 ngh\u1ECBch \u0111i\u1EC7n th\u1EBF n\xE0o n\u1ED5 lu\xF4n
      m\u1EDBi kinh."
    displayMode: 2
    avatar: {fileID: 0}
    showAvatar: 0
    changeBackground: 0
    background: {fileID: 0}
    backgroundColor: {r: 1, g: 1, b: 1, a: 1}
    clearBackground: 0
    voiceClip: {fileID: 0}
    soundEffect: {fileID: 0}
    eventKey: 
    inputLockDuration: 0
    autoContinue: 0
    autoContinueDelay: 1
  - speakerName: "Ng\u01B0\u1EDDi qua \u0111\u01B0\u1EDDng 2"
    content: "Ch\u1ECBu th\u1EE3. N\xE0y h\u1ECDc l\u1EA1i l\u1EA7n 4 cho nh\u1EDB."
