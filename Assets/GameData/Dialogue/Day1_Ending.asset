  - speakerName: "Uncle H\u1EA3i"
    content: "T\u1EEB mai sinh vi\xEAn v\xE0 c\xE1n b\u1ED9 mu\u1ED1n v\xE0o C7 ph\u1EA3i
      c\xF3 Gi\u1EA5y Ph\xE9p ra v\xE0o c\xF3 hi\u1EC7u l\u1EF1c trong ng\xE0y."
    displayMode: 0
    avatar: {fileID: 0}
    showAvatar: 1
    changeBackground: 0
    background: {fileID: 0}
    backgroundColor: {r: 1, g: 1, b: 1, a: 1}
    clearBackground: 0
    voiceClip: {fileID: 0}
    soundEffect: {fileID: 0}
    eventKey: 
    inputLockDuration: 0
    autoContinue: 0
    autoContinueDelay: 1
  - speakerName: "V\u0169"
    content: "Sao t\u1EF1 nhi\xEAn ch\u1EB7t v\u1EADy th\u1EA7y?"
    displayMode: 0
    avatar: {fileID: 0}
    showAvatar: 1
    changeBackground: 0
    background: {fileID: 0}
    backgroundColor: {r: 1, g: 1, b: 1, a: 1}
    clearBackground: 0
    voiceClip: {fileID: 0}
    soundEffect: {fileID: 0}
    eventKey: 
    inputLockDuration: 0
    autoContinue: 0
    autoContinueDelay: 1
  - speakerName: "Uncle H\u1EA3i"
    content: "C\xF3 sinh vi\xEAn l\xE0m h\u1ECFng h\u1EC7 th\u1ED1ng \u0111i\u1EC7n
      ch\xEDnh c\u1EE7a to\xE0n b\u1ED9 t\u1EA7ng 7 v\xE0 t\u1EA7ng 8 r\u1ED3i. Trong
      ng\xE0y mai tr\u01B0\u1EDDng s\u1EBD s\u1EEDa l\u1EA1i h\u1EC7 th\u1ED1ng \u0111i\u1EC7n
      c\u1EE7a ph\xF2ng nghi\xEAn c\u1EE9u."
    displayMode: 0
    avatar: {fileID: 0}
    showAvatar: 1
    changeBackground: 0
    background: {fileID: 0}
    backgroundColor: {r: 1, g: 1, b: 1, a: 1}
    clearBackground: 0
    voiceClip: {fileID: 0}
    soundEffect: {fileID: 0}
