  - speakerName: "Uncle H\u1EA3i"
    showAvatar: 1
    avatar: {fileID: 0}
    content: "Nhi\u1EC7m v\u1EE5 c\u1EE7a em l\xE0 \u0111\u1ED1i chi\u1EBFu th\xF4ng
