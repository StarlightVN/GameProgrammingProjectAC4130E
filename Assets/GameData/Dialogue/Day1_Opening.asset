  m_Script: {fileID: 0}
  m_Name: Day1_Opening
  m_EditorClassIdentifier: Assembly-CSharp:LetMeIn.Dialogue:StoryDialogueSequence
  sequenceId: DAY1_OPENING
  sequenceTitle: "Ng\xE0y 1 - M\u1EDF \u0111\u1EA7u"
  description: "Ph\u1EA7n m\u1EDF \u0111\u1EA7u ng\xE0y 1. T\u1EA1m tr\xECnh b\xE0y
    d\u01B0\u1EDBi d\u1EA1ng dialogue."
  defaultCharacterInterval: 0.025
  hideAfterFinished: 1
  lines:
  - speakerName: 
    content: "N\u0103m 2026, th\u1EBF gi\u1EDBi b\u01B0\u1EDBc v\xE0o k\u1EC9 nguy\xEAn
      v\u01B0\u01A1n m\xECnh."
    displayMode: 1
    avatar: {fileID: 0}
    showAvatar: 0
    changeBackground: 1
    background: {fileID: -4039747514390058332, guid: 889538ee0f6279c4587dc0a241397174, type: 3}
    backgroundColor: {r: 0.27450982, g: 0.27450982, b: 0.27450982, a: 1}
    clearBackground: 0
    voiceClip: {fileID: 0}
    soundEffect: {fileID: 0}
    eventKey: ChangeBG_Era
    inputLockDuration: 0
    autoContinue: 0
    autoContinueDelay: 1
  - speakerName: 
    content: "\u0110\u1EA1i h\u1ECDc Back khoa H\xE0 N\u1ED9i \u0111\xE3 ti\u1EBFn
      v\xE0o top 36 QS Ranking tr\xEAn to\xE0n v\u0169 tr\u1EE5, thu h\xFAt h\xE0ng
      tri\u1EC7u sinh vi\xEAn k\u1EF3 l\u1EA1 t\u1EEB kh\u1EAFp c\xE1c h\xE0nh tinh."
    displayMode: 1
    avatar: {fileID: 0}
    showAvatar: 0
    changeBackground: 1
    background: {fileID: -4039747514390058332, guid: 889538ee0f6279c4587dc0a241397174, type: 3}
    backgroundColor: {r: 1, g: 1, b: 1, a: 1}
    clearBackground: 0
    voiceClip: {fileID: 0}
    soundEffect: {fileID: 0}
    eventKey: 
    inputLockDuration: 0
    autoContinue: 0
    autoContinueDelay: 1
  - speakerName: 
    content: "B\u1EA1n l\xE0 V\u0169 - con ng\u01B0\u1EDDi, c\u1ED5 \u0111\xF4ng
      n\u0103m 3 \u0110\u1EA1i h\u1ECDc Back khoa H\xE0 N\u1ED9i - s\u1EAFp b\u1ECB
      \u0111u\u1ED5i h\u1ECDc v\xEC s\u1EAFp hai k\u1EF3 li\xEAn ti\u1EBFp d\u01B0\u1EDBi
      36 \u0111i\u1EC3m."
    displayMode: 1
    avatar: {fileID: 0}
    showAvatar: 0
    changeBackground: 1
    background: {fileID: -4039747514390058332, guid: 889538ee0f6279c4587dc0a241397174, type: 3}
    backgroundColor: {r: 1, g: 1, b: 1, a: 1}
    clearBackground: 0
    voiceClip: {fileID: 0}
    soundEffect: {fileID: 0}
    eventKey: 
    inputLockDuration: 0
    autoContinue: 0
    autoContinueDelay: 1
  - speakerName: "V\u0169"
    content: "Qu\u1EA3 n\xE0y s\u1EAFp \u0103n c\u1EA3nh c\xE1o 3 r\u1ED3i!"
    displayMode: 0
    avatar: {fileID: -5997611074763894696, guid: 412511064ffb7b545b7c06ae3f43bf05, type: 3}
    showAvatar: 1
    changeBackground: 0
    background: {fileID: 0}
    backgroundColor: {r: 1, g: 1, b: 1, a: 1}
    clearBackground: 1
    voiceClip: {fileID: 0}
    soundEffect: {fileID: 0}
    eventKey: 
    inputLockDuration: 0
    autoContinue: 0
    autoContinueDelay: 1
  - speakerName: 
    content: "V\u1EDBi s\u1EF1 gi\u1EDBi thi\u1EC7u t\u1EEB Uncle H\u1EA3i, hi\u1EC7n
      \u0111ang l\xE0m ch\u1EE7 nhi\u1EC7m CLB T\xECnh nguy\u1EC7n trong tr\u01B0\u1EDDng,
      b\u1EA1n \u0111\u01B0\u1EE3c s\u1EAFp x\u1EBFp \u0111i h\u1ED7 tr\u1EE3 c\xF4ng
      vi\u1EC7c b\u1EA3o v\u1EC7 cho t\xF2a C7-x\u1ECBn nh\u1EA5t tr\u01B0\u1EDDng."
    displayMode: 1
    avatar: {fileID: 0}
    showAvatar: 0
    changeBackground: 0
    background: {fileID: 0}
    backgroundColor: {r: 1, g: 1, b: 1, a: 1}
    clearBackground: 0
    voiceClip: {fileID: 0}
    soundEffect: {fileID: 0}
    eventKey: 
    inputLockDuration: 0
    autoContinue: 0
    autoContinueDelay: 1
  - speakerName: 
    content: "Nhi\u1EC7m v\u1EE5 c\u1EE7a b\u1EA1n l\xE0 \u0111\u1EA3m b\u1EA3o t\u1EA5t
      c\u1EA3 sinh vi\xEAn \u0111\u1EC1u \u0111eo th\u1EBB \u0111\u1EA7y \u0111\u1EE7
      v\xE0 \u0111\u01B0\u1EE3c x\xE1c minh th\xE2n ph\u1EADn tr\u01B0\u1EDBc khi
      v\xE0o C7."
    displayMode: 1
    avatar: {fileID: 0}
    showAvatar: 0
    changeBackground: 0
    background: {fileID: 0}
    backgroundColor: {r: 1, g: 1, b: 1, a: 1}
    clearBackground: 0
    voiceClip: {fileID: 0}
    soundEffect: {fileID: 0}
    eventKey: 
    inputLockDuration: 0
    autoContinue: 0
    autoContinueDelay: 1
  - speakerName: "V\u0169"
    content: "Sinh vi\xEAn l\xE0m t\xECnh"
    displayMode: 0
    avatar: {fileID: 0}
    showAvatar: 1
    changeBackground: 0
    background: {fileID: 4233822279838665315, guid: c42a61a37fef72d4e930d30d851e9d54, type: 3}
    backgroundColor: {r: 1, g: 1, b: 1, a: 1}
    clearBackground: 1
    voiceClip: {fileID: 0}
    soundEffect: {fileID: 0}
