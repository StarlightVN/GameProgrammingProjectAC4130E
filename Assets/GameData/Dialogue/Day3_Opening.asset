    showAvatar: 1
    avatar: {fileID: -572214486208604857, guid: 93ae804d88b14184289223f733bafd37, type: 3}
    content: "\u0110\xFAng. Nh\u01B0ng sinh vi\xEAn nghi\xEAn c\u1EE9u ph\u1EA3i
      c\xF3 <color=#FFD54A>Gi\u1EA5y Ch\u1EE9ng Nh\u1EADn Th\xE0nh Vi\xEAn Ph\xF2ng
