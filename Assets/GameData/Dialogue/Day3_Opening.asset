  - speakerName: "V\u0169"
    showAvatar: 1
    avatar: {fileID: 3017366831401090874, guid: 5fbf05b44113edec98b5f4530f1b03ab, type: 3}
    content: "Yasss, v\u1EADy l\xE0 em kh\xF4ng c\u1EA7n check gi\u1EA5y t\u1EDD
      n\u1EEFa \u0111\xFAng kh\xF4ng \u1EA1?"
    displayMode: 0
    changeBackground: 0
    clearBackground: 0
    background: {fileID: 0}
    backgroundColor: {r: 1, g: 1, b: 1, a: 1}
    voiceClip: {fileID: 0}
    soundEffect: {fileID: 0}
    eventKey: 
    inputLockDuration: 0
    autoContinue: 0
    useTypewriterSound: 1
    autoContinueDelay: 2
  - speakerName: "Uncle H\u1EA3i"
    showAvatar: 1
    avatar: {fileID: -572214486208604857, guid: 93ae804d88b14184289223f733bafd37, type: 3}
    content: "Kh\xF4ng, h\xF4m nay s\u1EBD c\xF3 r\u1EA5t nhi\u1EC1u ng\u01B0\u1EDDi,
      check c\u1EA9n th\u1EADn v\xE0o. H\xF4m nay kh\xF4ng c\xF3 l\u1EDBp h\u1ECDc.
      Ai v\xE0o v\u1EDBi m\u1EE5c \u0111\xEDch \u0111i h\u1ECDc th\xEC t\u1EEB ch\u1ED1i."
    displayMode: 0
    changeBackground: 0
    clearBackground: 0
    background: {fileID: 0}
    backgroundColor: {r: 1, g: 1, b: 1, a: 1}
    voiceClip: {fileID: 0}
    soundEffect: {fileID: 0}
    eventKey: 
    inputLockDuration: 0
    autoContinue: 0
    useTypewriterSound: 1
    autoContinueDelay: 2
  - speakerName: "V\u0169"
    showAvatar: 1
    avatar: {fileID: 3017366831401090874, guid: 5fbf05b44113edec98b5f4530f1b03ab, type: 3}
    content: "V\u1EADy l\xE0 <color=#FFD54A>ch\u1EC9 \u0111\u01B0\u1EE3c v\xE0o v\xEC
      m\u1EE5c \u0111\xEDch S\u1EF1 ki\u1EC7n ho\u1EB7c Nghi\xEAn c\u1EE9u</color>
      \u1EA1?"
    displayMode: 0
    changeBackground: 0
    clearBackground: 0
    background: {fileID: 0}
    backgroundColor: {r: 1, g: 1, b: 1, a: 1}
    voiceClip: {fileID: 0}
    soundEffect: {fileID: 0}
