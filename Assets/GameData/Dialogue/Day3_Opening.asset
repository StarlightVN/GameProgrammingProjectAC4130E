  - speakerName: "Ng\u01B0\u1EDDi qua \u0111\u01B0\u1EDDng 3"
    showAvatar: 1
    avatar: {fileID: -1593477784551811952, guid: a01e938b340d98bcf91e06cfccc761c3, type: 3}
    content: "\u0110i\u1EC3m r\xE8n luy\u1EC7n th\xEC sao m?"
    displayMode: 0
    changeBackground: 0
    clearBackground: 0
    background: {fileID: 0}
    backgroundColor: {r: 1, g: 1, b: 1, a: 1}
    voiceClip: {fileID: 0}
