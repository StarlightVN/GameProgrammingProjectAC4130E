  - speakerName: 
    showAvatar: 0
    avatar: {fileID: -165899576139747431, guid: 53062d33ea634c9438a45f12a08a853f, type: 3}
    content: "C\u1ED5ng C7 h\xF4m nay \u0111\u01B0\u1EE3c d\xE1n m\u1ED9t t\u1EDD
      gi\u1EA5y vi\u1EBFt tay m\u1EDBi c\u1EE7a V\u0169."
    displayMode: 1
    changeBackground: 1
    clearBackground: 0
    background: {fileID: 0}
    backgroundColor: {r: 1, g: 1, b: 1, a: 1}
    voiceClip: {fileID: 0}
    soundEffect: {fileID: 0}
