    inputLockDuration: 0
    autoContinue: 0
    useTypewriterSound: 1
    autoContinueDelay: 2
  - speakerName: 
    showAvatar: 0
    avatar: {fileID: 0}
    content: "\u201CNg\xE0y h\u1ED9i sinh vi\xEAn - Vui l\xE0 ch\xEDnh, gi\u1EA5y
      t\u1EDD l\xE0 b\u1EAFt bu\u1ED9c.\u201D"
    displayMode: 1
    changeBackground: 0
    clearBackground: 0
    background: {fileID: 0}
    backgroundColor: {r: 1, g: 1, b: 1, a: 1}
    voiceClip: {fileID: 0}
    soundEffect: {fileID: 0}
