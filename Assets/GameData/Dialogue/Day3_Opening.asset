    autoContinue: 0
    useTypewriterSound: 1
    autoContinueDelay: 2
  - speakerName: "Ng\u01B0\u1EDDi qua \u0111\u01B0\u1EDDng 1"
    showAvatar: 1
    avatar: {fileID: -1593477784551811952, guid: a01e938b340d98bcf91e06cfccc761c3, type: 3}
    content: "Mai l\xE0 Ng\xE0y h\u1ED9i sinh vi\xEAn \u0111\u1EA5y, \u0111\u01B0\u1EE3c
      ngh\u1EC9 h\u1ECDc nh\xE9. \u0110i net kh\xF4ng anh em?"
    displayMode: 0
    changeBackground: 0
    clearBackground: 0
    background: {fileID: 0}
    backgroundColor: {r: 1, g: 1, b: 1, a: 1}
    voiceClip: {fileID: 0}
    soundEffect: {fileID: 0}
    eventKey: 
    inputLockDuration: 0
    autoContinue: 0
    useTypewriterSound: 1
    autoContinueDelay: 2
  - speakerName: "Ng\u01B0\u1EDDi qua \u0111\u01B0\u1EDDng 2"
    showAvatar: 1
    avatar: {fileID: -1593477784551811952, guid: a01e938b340d98bcf91e06cfccc761c3, type: 3}
    content: "Ok \u0111i l\xE0m t\xED Javalorant."
    displayMode: 0
    changeBackground: 0
    clearBackground: 0
    background: {fileID: 0}
    backgroundColor: {r: 1, g: 1, b: 1, a: 1}
    voiceClip: {fileID: 0}
    soundEffect: {fileID: 0}
