  - speakerName: "Uncle H\u1EA3i"
    showAvatar: 1
    avatar: {fileID: -7697912950109865086, guid: 01a73767b53ba1942aa36c60bf4b6493, type: 3}
    content: "Nay l\xE0 Ng\xE0y h\u1ED9i sinh vi\xEAn."
    displayMode: 0
    changeBackground: 1
    clearBackground: 0
    background: {fileID: 2826988517474644282, guid: e16da847f27a4d547903e4052f6ee8d2, type: 3}
