  lines:
  - speakerName: 
    showAvatar: 0
    avatar: {fileID: 0}
    content: "Cu\u1ED1i ng\xE0y, m\u1ED9t nh\xF3m sinh vi\xEAn SEEE khi th\xED nghi\u1EC7m
      L\xFD thuy\u1EBFt m\u1EA1ch \u0111\xE3 v\xF4 t\xECnh c\u1EAFm m\u1EA1ch v\xE0o
      ngu\u1ED3n \u0111i\u1EC7n t\u1ED5ng."
