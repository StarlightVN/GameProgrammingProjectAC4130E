    inputLockDuration: 0
    autoContinue: 0
    useTypewriterSound: 1
    autoContinueDelay: 1
  - speakerName: "Ng\u01B0\u1EDDi qua \u0111\u01B0\u1EDDng 2"
    showAvatar: 1
    avatar: {fileID: -1593477784551811952, guid: a01e938b340d98bcf91e06cfccc761c3, type: 3}
    content: "O\xE1ch x\xE0 l\xE1ch. Ch\u1EAFc m\u1EDBi t\u1EA1ch Gi\u1EA3i t\xEDch
