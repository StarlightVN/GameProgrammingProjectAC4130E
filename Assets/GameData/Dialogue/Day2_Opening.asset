  - speakerName: "Uncle H\u1EA3i"
    showAvatar: 1
    avatar: {fileID: 0}
    content: "C\xF3 sinh vi\xEAn l\xE0m h\u1ECFng h\u1EC7 th\u1ED1ng \u0111i\u1EC7n
