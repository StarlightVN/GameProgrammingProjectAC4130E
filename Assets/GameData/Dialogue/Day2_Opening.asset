  - speakerName: "Ng\u01B0\u1EDDi qua \u0111\u01B0\u1EDDng 1"
    showAvatar: 0
    avatar: {fileID: 0}
    content: "V\xE3i n\xE3y c\xF3 th\u1EB1ng l\xE0m n\u1ED5 lu\xF4n c\u1EA7u dao
