  defaultCharacterInterval: 0.018
  hideAfterFinished: 1
  lines:
  - speakerName: 
    content: "H\xF4m nay l\xE0 ch\u1EE7 nh\u1EADt, Tr\u01B0\u1EDDng \u0110i\u1EC7n
      - \u0110i\u1EC7n t\u1EED t\u1ED5 ch\u1EE9c H\u1ED9i ngh\u1ECB trong t\xF2a
      nh\xE0 v\xE0 c\xF3 sinh vi\xEAn \u0111\u1EBFn tham d\u1EF1.\n\nCh\u1EC9 c\xF3
      sinh vi\xEAn SEEE v\xE0 c\xE1n b\u1ED9 m\u1EDBi \u0111\u01B0\u1EE3c v\xE0o
      t\xF2a nh\xE0."
    displayMode: 3
    avatar: {fileID: 0}
    showAvatar: 0
    changeBackground: 0
    background: {fileID: 0}
    backgroundColor: {r: 1, g: 1, b: 1, a: 1}
    clearBackground: 0
