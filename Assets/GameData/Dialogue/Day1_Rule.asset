    inputLockDuration: 0
    autoContinue: 0
    autoContinueDelay: 1
  - speakerName: 
    content: "Sinh vi\xEAn ph\u1EA3i xu\u1EA5t tr\xECnh Th\u1EBB Sinh Vi\xEAn h\u1EE3p
      l\u1EC7.\n\nC\xE1n b\u1ED9 ph\u1EA3i xu\u1EA5t tr\xECnh Th\u1EBB C\xE1n B\u1ED9
      h\u1EE3p l\u1EC7."
    displayMode: 3
    avatar: {fileID: 0}
    showAvatar: 0
    changeBackground: 0
    background: {fileID: 0}
    backgroundColor: {r: 1, g: 1, b: 1, a: 1}
    clearBackground: 0
    voiceClip: {fileID: 0}
    soundEffect: {fileID: 0}
    eventKey: ShowMainCardTutorial
    inputLockDuration: 0
    autoContinue: 0
    autoContinueDelay: 1
  - speakerName: 
    content: "H\xE3y \u0111\u1ED1i chi\u1EBFu t\xEAn, \u1EA3nh ch\xE2n dung, khoa/tr\u01B0\u1EDDng,
      ng\xE0nh h\u1ECDc v\xE0 th\u1EDDi h\u1EA1n c\u1EE7a gi\u1EA5y t\u1EDD tr\u01B0\u1EDBc
      khi \u0111\u01B0a ra quy\u1EBFt \u0111\u1ECBnh."
