  m_Script: {fileID: 0}
  m_Name: Day1_Tutorial
  m_EditorClassIdentifier: Assembly-CSharp:LetMeIn.Dialogue:StoryDialogueSequence
  sequenceId: DAY1_TUTORIAL
  sequenceTitle: "Ng\xE0y 1 - Tutorial"
  description: "Uncle H\u1EA3i h\u01B0\u1EDBng d\u1EABn V\u0169 l\xE0m nhi\u1EC7m
    v\u1EE5."
  defaultCharacterInterval: 0.025
  hideAfterFinished: 1
  lines:
  - speakerName: "Uncle H\u1EA3i"
    content: "V\u0169 \xE0 V\u0169, t\u1EEB nay em s\u1EBD tham gia h\u1ED7 tr\u1EE3
      ki\u1EC3m tra th\xF4ng tin ng\u01B0\u1EDDi ra v\xE0o C7."
    displayMode: 0
    avatar: {fileID: 0}
    showAvatar: 1
    changeBackground: 0
    background: {fileID: 0}
    backgroundColor: {r: 1, g: 1, b: 1, a: 1}
    clearBackground: 0
    voiceClip: {fileID: 0}
    soundEffect: {fileID: 0}
    eventKey: ChangeBG_MainScreen
    inputLockDuration: 0
    autoContinue: 0
    autoContinueDelay: 1
  - speakerName: "V\u0169"
    content: "D\u1EA1, em t\u01B0\u1EDFng l\xE0m t\xECnh nguy\u1EC7n l\xE0 x\xE1ch
      n\u01B0\u1EDBc b\u1ED5 cam \u1EA1?"
    displayMode: 0
    avatar: {fileID: 0}
    showAvatar: 1
    changeBackground: 0
    background: {fileID: 0}
    backgroundColor: {r: 1, g: 1, b: 1, a: 1}
    clearBackground: 0
    voiceClip: {fileID: 0}
    soundEffect: {fileID: 0}
    eventKey: 
    inputLockDuration: 0
    autoContinue: 0
    autoContinueDelay: 1
  - speakerName: "Uncle H\u1EA3i"
    content: ...
    displayMode: 0
    avatar: {fileID: 0}
    showAvatar: 1
    changeBackground: 0
    background: {fileID: 0}
    backgroundColor: {r: 1, g: 1, b: 1, a: 1}
    clearBackground: 0
    voiceClip: {fileID: 0}
    soundEffect: {fileID: 0}
    eventKey: 
    inputLockDuration: 0
    autoContinue: 0
    autoContinueDelay: 1
  - speakerName: "Uncle H\u1EA3i"
    content: "Nhi\u1EC7m v\u1EE5 c\u1EE7a em l\xE0 \u0111\u1ED1i chi\u1EBFu th\xF4ng
      tin tr\xEAn Th\u1EBB Sinh Vi\xEAn v\xE0 c\xE1c gi\u1EA5y t\u1EDD li\xEAn quan
      v\u1EDBi S\u1ED5 tay h\u01B0\u1EDBng d\u1EABn \u0111\u1EC3 quy\u1EBFt \u0111\u1ECBnh
      cho ng\u01B0\u1EDDi \u0111\xF3 v\xE0o hay cook."
    displayMode: 0
    avatar: {fileID: 0}
    showAvatar: 1
    changeBackground: 0
    background: {fileID: 0}
    backgroundColor: {r: 1, g: 1, b: 1, a: 1}
    clearBackground: 0
    voiceClip: {fileID: 0}
    soundEffect: {fileID: 0}
    eventKey: 
    inputLockDuration: 0
    autoContinue: 0
    autoContinueDelay: 1
  - speakerName: "Uncle H\u1EA3i"
    content: "Sau khi nh\u1EADn \u0111\u01B0\u1EE3c th\u1EBB t\u1EEB ng\u01B0\u1EDDi
      ra v\xE0o, em h\xE3y c\u1EA7m sang b\xE0n b\xEAn ph\u1EA3i \u0111\u1EC3 ki\u1EC3m
      tra th\xF4ng tin th\u1EADt k\u1EF9, r\u1ED3i b\u1EA5m n\xFAt \u1EDF kia \u0111\u1EC3
      m\u1EDF c\u1EEDa nh\xE9. Kh\xF4ng \u0111\u1EE7 th\xEC \u0111\u1EEBng cho v\xE0o."
    displayMode: 0
    avatar: {fileID: 0}
    showAvatar: 1
    changeBackground: 0
    background: {fileID: 0}
    backgroundColor: {r: 1, g: 1, b: 1, a: 1}
    clearBackground: 0
    voiceClip: {fileID: 0}
    soundEffect: {fileID: 0}
    eventKey: Tutorial_CheckDocument
    inputLockDuration: 0
    autoContinue: 0
    autoContinueDelay: 1
  - speakerName: "Uncle H\u1EA3i"
    content: "Nh\u1EDB l\xE0 h\xF4m nay c\xF3 H\u1ED9i ngh\u1ECB \u0110\u1ED5i m\u1EDBi
      s\xE1ng t\u1EA1o \u1EDF s\u1EA3nh C7 v\xE0 t\u1EA7ng 8, n\xEAn ch\u1EC9 c\xF3
      sinh vi\xEAn SEEE v\xE0 c\xE1n b\u1ED9 \u0111\u01B0\u1EE3c v\xE0o nh\xE9!"
    displayMode: 0
    avatar: {fileID: 0}
    showAvatar: 1
    changeBackground: 0
    background: {fileID: 0}
    backgroundColor: {r: 1, g: 1, b: 1, a: 1}
    clearBackground: 0
    voiceClip: {fileID: 0}
    soundEffect: {fileID: 0}
    eventKey: 
    inputLockDuration: 0
    autoContinue: 0
    autoContinueDelay: 1
  - speakerName: "V\u0169"
    content: "V\u1EADy l\xE0 em c\u1EA7n ki\u1EC3m tra Th\u1EBB Sinh Vi\xEAn v\xE0
      Th\u1EBB C\xE1n B\u1ED9 \u0111\xFAng kh\xF4ng \u1EA1?"
    displayMode: 0
    avatar: {fileID: 0}
    showAvatar: 1
    changeBackground: 0
    background: {fileID: 0}
    backgroundColor: {r: 1, g: 1, b: 1, a: 1}
    clearBackground: 0
    voiceClip: {fileID: 0}
    soundEffect: {fileID: 0}
    eventKey: 
    inputLockDuration: 0
    autoContinue: 0
    autoContinueDelay: 1
  - speakerName: "Uncle H\u1EA3i"
    content: "\u0110\xFAng r\u1ED3i em, ki\u1EC3m tra k\u1EF9 v\xE0o, \u0111\u1EEBng
      c\xF3 m\u1EDF c\u1EEDa sau cho \u0111\u1EE9a n\xE0o \u0111\u1EA5y!"
    displayMode: 0
    avatar: {fileID: 0}
    showAvatar: 1
    changeBackground: 0
    background: {fileID: 0}
    backgroundColor: {r: 1, g: 1, b: 1, a: 1}
    clearBackground: 0
    voiceClip: {fileID: 0}
    soundEffect: {fileID: 0}
    eventKey: 
    inputLockDuration: 0
    autoContinue: 0
    autoContinueDelay: 1
  - speakerName: "V\u0169"
    content: "C\xF3 c\u1EA7n ki\u1EC3m tra th\u1EA7n th\xE1i h\u1ECDc thu\u1EADt
      kh\xF4ng s\u1EBFp?"
    displayMode: 0
    avatar: {fileID: 0}
    showAvatar: 1
    changeBackground: 0
    background: {fileID: 0}
    backgroundColor: {r: 1, g: 1, b: 1, a: 1}
    clearBackground: 0
    voiceClip: {fileID: 0}
    soundEffect: {fileID: 0}
    eventKey: 
    inputLockDuration: 0
    autoContinue: 0
    autoContinueDelay: 1
  - speakerName: "Uncle H\u1EA3i"
    content: ...
    displayMode: 0
    avatar: {fileID: 0}
    showAvatar: 1
    changeBackground: 0
    background: {fileID: 0}
    backgroundColor: {r: 1, g: 1, b: 1, a: 1}
    clearBackground: 0
    voiceClip: {fileID: 0}
    soundEffect: {fileID: 0}
    eventKey: 
    inputLockDuration: 0
    autoContinue: 0
    autoContinueDelay: 1
  - speakerName: "Uncle H\u1EA3i"
    content: "Th\xF4i ki\u1EC3m tra c\xE1i \u0111\xF3 th\xEC n\u1EEDa tr\u01B0\u1EDDng
      kh\xF4ng \u0111\u01B0\u1EE3c v\xE0o."
    displayMode: 0
    avatar: {fileID: 0}
